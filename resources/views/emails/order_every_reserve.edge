                                                                 width="32" height="32" border="0"
                                                                 style="display: block; border-radius: 50%;" alt="Website" />
                                                          </a>
                                                        </td>
                                                        <td style="padding: 0 8px;">
                                                          <a href="{{instagram}}" target="_blank" style="text-decoration: none;">
