  <body text="#3b3f44" link="#0092ff" yahoo="fix">
    <table
      cellspacing="0"
      cellpadding="0"
      border="0"
      role="presentation"
      class="nl2go-body-table"
      width="100%"
      style="width: 100%"
    >
      <tr>
        <td>
          <table
            cellspacing="0"
            cellpadding="0"
            border="0"
            role="presentation"
            width="600"
            align="center"
            class="r0-o"
            style="table-layout: fixed; width: 600px"
          >
            <tr>
              <td valign="top">
                <table
                  cellspacing="0"
                  cellpadding="0"
                  border="0"
                  role="presentation"
                  width="100%"
                  align="center"
                  class="r1-o"
                  style="
                    background-color: #ffffff;
                    table-layout: fixed;
                    width: 100%;
                  "
                >
                  <tr>
                    <th
                      width="100%"
                      valign="top"
                      class="r2-c"
                      style="font-weight: normal"
                    >
                      <table
                        cellspacing="0"
                        cellpadding="0"
                        border="0"
                        role="presentation"
                        width="600"
                        align="center"
                        class="r4-o"
                        style="table-layout: fixed; width: 600px"
                      >
                        <tr>
                          <td
                            class="r5-i"
                            style="font-size: 0px; line-height: 0px"
                          >
                            <img
                              src="https://img.mailinblue.com/4873864/images/content_library/original/{{image}}"
                              width="600"
                              border="0"
                              style="display: block; width: 100%"
                            />
                          </td>
                        </tr>
                      </table>
                    </th>
                  </tr>
                </table>
                <table
                  cellspacing="0"
                  cellpadding="0"
                  border="0"
                  role="presentation"
                  width="100%"
                  align="center"
                  class="r1-o"
                  style="table-layout: fixed; width: 100%"
                >
                  <tr>
                    <td class="r7-i" style="background-color: #ffffff">
                      <table
                        width="100%"
                        cellspacing="0"
                        cellpadding="0"
                        border="0"
                        role="presentation"
                      >
                        <tr>
                          <th
                            width="100%"
                            valign="top"
                            class="r2-c"
                            style="font-weight: normal"
                          >
                            <table
                              cellspacing="0"
                              cellpadding="0"
                              border="0"
                              role="presentation"
                              width="100%"
                              class="r3-o"
                              style="table-layout: fixed; width: 100%"
                            >
                              <tr>
                                <td
                                  valign="top"
                                  class="r8-i"
                                  style="
                                    padding-left: 15px;
                                    padding-right: 15px;
                                  "
                                >
                                  <table
                                    width="100%"
                                    cellspacing="0"
                                    cellpadding="0"
                                    border="0"
                                    role="presentation"
                                  >
                                    <tr>
                                      <td
                                        class="r9-c nl2go-default-textstyle"
                                        align="center"
                                        style="
                                          color: #3b3f44;
                                          font-family: trebuchet ms, helvetica,
                                            sans-serif;
                                          font-size: 16px;
                                          line-height: 1.5;
                                          word-break: break-word;
                                          padding-top: 10px;
                                          text-align: center;
                                          valign: top;
                                        "
                                      >
                                        <table width="100%" cellspacing="0" cellpadding="0" border="0" role="presentation">
                                          <tr>
                                            <td style="padding: 0;">
                                              <span
                                                style="
                                                  font-family: 'Trebuchet ms',
                                                    helvetica, sans-serif;
                                                  font-size: 18px;
                                                "
                                                >¡Muchas gracias por tu
                                                <strong>compra</strong>!</span
                                              >
                                            </td>
                                          </tr>
                                          <tr>
                                            <td style="padding: 0;">
                                              <span style="font-size: 16px">
                                               Te recordamos que compraste productos en
                                                <strong>reserva</strong>
                                                ¡Tus productos aún no están en el país!
                                              </span>
                                            </td>
                                          </tr>
                                          <tr>
                                            <td style="padding: 0;">
                                              <span style="font-size: 16px">
                                                Puedes
                                                <strong
                                                  ><a
                                                    href="{{order.billing}}"
                                                    style="color: black"
                                                    >descargar tu boleta aqui</a
                                                  >.</strong
                                                >
                                              </span>
                                            </td>
                                          </tr>
                                        </table>
                                      </td>
                                    </tr>
                                  </table>
                                </td>
                              </tr>
                            </table>
                          </th>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>

                @if(is_store && imageDiscount && country ==='CHILE')
